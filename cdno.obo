[Term]
id: CHEBI:28057
name: amylopectin
namespace: chebi_ontology
alt_id: CHEBI:22538
alt_id: CHEBI:2693
def: "A polydisperse highly branched polysaccharide derivative composed of chains of <small>D</small>-glucopyranose residues in α(1→4) glycosidic linkage. The chains are joined together by α(1→6) glycosidic linkages. A small number of α(1→3) glycosidic linkages and some 6-phosphate ester groups also may occur. The branches in amylopectin typically contain 24 to 30 glucose residues." []
subset: 3:STAR
synonym: "Amylopectin" RELATED [kegg.compound]
