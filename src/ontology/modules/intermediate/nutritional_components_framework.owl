    <!-- http://purl.obolibrary.org/obo/BFO_0000040 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <obo:IAO_0000115 xml:lang="en">A material entity that is ingested and contributes to survival, growth and development</obo:IAO_0000115>
        <rdfs:label>dietary chemical component</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000001"/>
        <obo:IAO_0000115 xml:lang="en">Material which remains after the removal of water from plant matter.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym xml:lang="en">dry matter</oboInOwl:hasExactSynonym>
        <rdfs:label>dry plant matter</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_16646"/>
        <obo:IAO_0000115 xml:lang="en">Carbohydrates that are absorbed in the small intestine and provide carbohydrate for metabolism in monogastric animals.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym xml:lang="en">digestible carbohydrate</oboInOwl:hasExactSynonym>
        <rdfs:label>available carbohydrate</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000003"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">Carbohydrates that are absorbed in the small intestine and provide carbohydrate for metabolism in monogastric animals.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://openlibrary-repo.ecampusontario.ca/jspui/handle/123456789/830"/>
        <oboInOwl:hasDbXref rdf:resource="https://www.nature.com/articles/1602937"/>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000004 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000003"/>
        <obo:IAO_0000115 xml:lang="en">Available carbohydrate in monosaccharide and disaccharide form</obo:IAO_0000115>
        <rdfs:label>free sugar</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000004"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">Available carbohydrate in monosaccharide and disaccharide form</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://doi.org/10.3390/nu8090582"/>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000005 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000001"/>
        <obo:IAO_0000115 xml:lang="en">A carbohydrate or associated lignin that resists hydrolytic digestion in the small intestine of humans and other monogastric species, with fermentative digestion in the large intestine</obo:IAO_0000115>
        <rdfs:label>dietary fibre</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000005"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A carbohydrate or associated lignin that resists hydrolytic digestion in the small intestine of humans and other monogastric species, with fermentative digestion in the large intestine</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://www.ncbi.nlm.nih.gov/pmc/articles/PMC3614039/"/>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000006 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000005"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_16646"/>
        <obo:IAO_0000115 xml:lang="en">Dietary fibre which dissolves in water and is partially or completely fermented in the colon of monogastric animals by gut bacteria.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym xml:lang="en">water soluble dietary fibre</oboInOwl:hasExactSynonym>
        <rdfs:label>soluble dietary fibre</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000006"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">Dietary fibre which dissolves in water and is partially or completely fermented in the colon of monogastric animals by gut bacteria.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="http://dx.doi.org/10.20431/2454-6224.0310004"/>
        <oboInOwl:hasDbXref rdf:resource="https://doi.org/10.4141/A05-049"/>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000006"/>
        <obo:IAO_0000115 xml:lang="en">A portion of starch that cannot be digested by amylases in the small intestine</obo:IAO_0000115>
        <rdfs:label>resistant starch</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000007"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A portion of starch that cannot be digested by amylases in the small intestine</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://academic.oup.com/advances/article/4/6/587/4595564"/>
        <oboInOwl:hasDbXref rdf:resource="https://pubmed.ncbi.nlm.nih.gov/2998174/"/>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000008 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000005"/>
        <obo:IAO_0000115 xml:lang="en">Dietary fibre which does not dissolve in water and is inert to digestive enzymes in the upper gastrointestinal tract of monogastric animals, with variable fermentability in the large bowel.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym xml:lang="en">water insoluble dietary fibre</oboInOwl:hasExactSynonym>
        <rdfs:label>insoluble dietary fibre</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000008"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">Dietary fibre which does not dissolve in water and is inert to digestive enzymes in the upper gastrointestinal tract of monogastric animals, with variable fermentability in the large bowel.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Dietary_fiber#cite_note-Oregon-3"/>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000009 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_36080"/>
        <obo:IAO_0000115 xml:lang="en">A protein that accumulates in developing seeds or grains.</obo:IAO_0000115>
