        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CDNO_0000005"/>
        <obo:IAO_0000115 xml:lang="en">Dietary fibre of degree of polymerization (DP) &gt; 2 resistant to digestion and absorption in the human small intestine but that is partially or completely fermented by the large bowel microbiota.</obo:IAO_0000115>
        <rdfs:label>fermentable dietary fibre</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CDNO_0000034 -->

