    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_167164"/>
        <obo:IAO_0000115 xml:lang="en">Mineral nutrient that is present in a very low concentration within the diet</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym xml:lang="en">micromineral</oboInOwl:hasExactSynonym>
        <rdfs:label>trace element</rdfs:label>
    </owl:Class>
    


