    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CDNO_0000011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_167164"/>
        <obo:IAO_0000115 xml:lang="en">A mineral nutrient that represents a major proportion of the minerals required in the diet</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym xml:lang="en">macromineral</oboInOwl:hasExactSynonym>
        <rdfs:label>macro element</rdfs:label>
