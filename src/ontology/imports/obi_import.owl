        <obo:IAO_0000115 xml:lang="en">An International Federation of Gynecology and Obstetrics cervical cancer stage value specification indicating invasive carcinoma which can be diagnosed only by microscopy, with deepest invasion &lt;5 mm and the largest extension &lt;7 mm.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Stage IA</obo:IAO_0000118>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Cervical_cancer_staging</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>Stage IA (FIGO)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002328 -->

