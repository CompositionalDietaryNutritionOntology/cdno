        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A decision tree building data transformation is a data transformation that has objective decision tree induction.</obo:IAO_0000115>
        <obo:IAO_0000117>James Malone</obo:IAO_0000117>
        <obo:IAO_0000119 xml:lang="en">PERSON: James Malone</obo:IAO_0000119>
        <rdfs:label xml:lang="en">decision tree building data transformation</rdfs:label>
    </owl:Class>
    


