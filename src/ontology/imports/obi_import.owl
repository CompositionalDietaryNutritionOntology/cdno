    <!-- http://purl.obolibrary.org/obo/OBI_0002229 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002229">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002224"/>
        <obo:IAO_0000111>pT3 (colon)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A pathologic primary tumor stage for colon and rectum according to AJCC 7th edition indicating that the tumor invades subserosa or into non-peritionealized pericolic or perirectal tissues.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
