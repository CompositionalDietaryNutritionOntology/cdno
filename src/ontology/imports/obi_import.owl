    <!-- http://purl.obolibrary.org/obo/OBI_0000726 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000726">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0200000"/>
        <obo:IAO_0000111>peak matching</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000123"/>
        <obo:IAO_0000115 xml:lang="en">Peak matching is a data transformation performed on a dataset of a graph of ordered data points (e.g. a spectrum) with the objective of pattern matching local maxima above a noise threshold</obo:IAO_0000115>
