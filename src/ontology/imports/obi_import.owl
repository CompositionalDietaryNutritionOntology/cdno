        <obo:IAO_0000115 xml:lang="en">A histologic grade for ovarian tumor that is from a histological classification by the World Health Organization (WHO).</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000119>NCI BBRB, OBI</obo:IAO_0000119>
