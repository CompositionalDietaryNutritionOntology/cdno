        <rdfs:label>G1: Well differentiated</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002207 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002207">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002205"/>
        <obo:IAO_0000111>G2: Moderately differentiated</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A histologic grade according to AJCC 7th edition indicating that the tumor cells are moderately differentiated and reflect an intermediate grade.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>G2</obo:IAO_0000118>
