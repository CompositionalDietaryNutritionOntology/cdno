        <obo:IAO_0000112>G4: Undifferentiated</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A categorical value specification that is a histologic grade assigned to a tumor slide specimen according to the American Joint Committee on Cancer (AJCC) 7th Edition grading system.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000119>NCI BBRB, OBI</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>histologic grade according to AJCC 7th edition</rdfs:label>
    </owl:Class>
    


