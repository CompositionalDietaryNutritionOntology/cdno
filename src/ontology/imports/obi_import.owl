    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000648">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
