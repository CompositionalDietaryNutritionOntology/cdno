        <obo:IAO_0000112>A clustered data set is the output of a K means clustering data transformation</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000125"/>
        <obo:IAO_0000115 xml:lang="en">A data set that is produced as the output of a class discovery data transformation and consists of a data set with assigned discovered class labels.</obo:IAO_0000115>
