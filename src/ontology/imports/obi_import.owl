        <rdfs:label>Stage IA1 (FIGO)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002329 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002329">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002326"/>
        <obo:IAO_0000111>Stage IA2 (FIGO)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">An International Federation of Gynecology and Obstetrics cervical cancer stage value specification indicating measured stromal invasion of &gt;3.0 mm and not &gt;5.0 mm with an extension of not &gt;7.0 mm.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Stage IA2</obo:IAO_0000118>
