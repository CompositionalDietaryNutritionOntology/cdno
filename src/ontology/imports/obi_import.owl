        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A pathologic primary tumor stage for lung according to AJCC 7th edition indicating carcinoma in situ.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000119>https://staging.seer.cancer.gov/tnm/input/1.0/lung/path_t/</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>pTis (lung)</rdfs:label>
