    <!-- http://purl.obolibrary.org/obo/OBI_0000659 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000659">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/COB_0000035"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000417"/>
