        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">An International Federation of Gynecology and Obstetrics cervical cancer stage value specification indicating measured stromal invasion of &lt;3.0 mm in depth and extension of &lt;7.0 mm.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000118>Stage IA1</obo:IAO_0000118>
