    <!-- http://purl.obolibrary.org/obo/OBI_0002250 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002250">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002243"/>
