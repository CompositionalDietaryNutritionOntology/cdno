        <obo:IAO_0000111>data visualization</obo:IAO_0000111>
        <obo:IAO_0000112>Generation of a heatmap from a microarray dataset</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A planned process with the objective to graphically represent some data by inputing the data and outputting images, diagrams or animations.</obo:IAO_0000115>
        <obo:IAO_0000117 xml:lang="en">Elisabetta Manduchi</obo:IAO_0000117>
        <obo:IAO_0000117 xml:lang="en">James Malone</obo:IAO_0000117>
