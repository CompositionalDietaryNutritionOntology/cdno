        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">a software that provides access to more than 100 tools for gene expression analysis, proteomics, SNP analysis and common data processing tasks.</obo:IAO_0000115>
        <obo:IAO_0000117>James Malone</obo:IAO_0000117>
        <obo:IAO_0000117>Person:Helen Parkinson</obo:IAO_0000117>
        <obo:IAO_0000119>WEB: http://www.broadinstitute.org/cancer/software/genepattern/</obo:IAO_0000119>
