        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>Stage IA2 (FIGO)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002330 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002330">
